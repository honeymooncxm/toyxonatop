# Шаблон переменных окружения для ПРОДАКШЕНА (не для локальной разработки).
# Скопируйте эти переменные в настройки проекта на Vercel (Settings → Environment
# Variables) — реальный .env файл на сервер не загружается и не нужен.

# Строка подключения к реальной PostgreSQL базе (Neon, Supabase, Vercel Postgres...).
# Получаете её в панели вашего провайдера базы данных после создания проекта.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Длинный случайный секрет для подписи JWT-токенов авторизации.
# Сгенерировать: openssl rand -base64 48
JWT_SECRET="ЗАМЕНИТЕ-НА-ДЛИННУЮ-СЛУЧАЙНУЮ-СТРОКУ"

# Реальный email и пароль администратора. Пароль — надёжный, не "Admin123!".
ADMIN_EMAIL="admin@ваш-домен.uz"
ADMIN_PASSWORD="ЗАМЕНИТЕ-НА-НАДЁЖНЫЙ-ПАРОЛЬ"

# Секретный путь к админ-панели вместо /admin (например "hall-control-x7k9").
# Придумайте свой уникальный вариант — не используйте пример из этого файла.
NEXT_PUBLIC_ADMIN_PATH="ЗАМЕНИТЕ-НА-СВОЙ-СЕКРЕТНЫЙ-ПУТЬ"

# Cloudinary — для реальной загрузки фото залов (создать бесплатный аккаунт на cloudinary.com)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Необязательно — нужно только если захотите подключить JS Google Maps SDK.
# Карты и так работают без ключа (встроенная ссылка на Google Maps).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Resend — рекомендую подключить для боевого запуска: письмо на почту при
# подозрительной активности входа в аккаунт (registration на resend.com, бесплатно)
RESEND_API_KEY=""
SECURITY_ALERT_EMAIL="admin@ваш-домен.uz"

# reCAPTCHA v3 — рекомендую подключить, чтобы боты не спамили формы
# регистрации/добавления зала (ключи на google.com/recaptcha, бесплатно)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

NEXT_PUBLIC_SITE_NAME="To'yxonaTop"
