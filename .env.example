# Database (SQLite for local dev — swap to a Postgres URL + change prisma/schema.prisma
# provider to "postgresql" for production, e.g. Neon/Supabase/Railway)
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="replace-with-a-long-random-string"

# Seeded admin account (created by prisma/seed.ts)
ADMIN_EMAIL="admin@toyxonatop.uz"
ADMIN_PASSWORD="change-me"

# Obscures the admin panel URL. Once set to anything other than "admin",
# /admin stops resolving (404) and only /<this value> works. This is
# obscurity, not real access control — the real gate is the ADMIN-role
# session check, but it does stop automated bots probing /admin, /wp-admin, etc.
NEXT_PUBLIC_ADMIN_PATH="admin"

# Cloudinary (optional — leave blank to fall back to local/placeholder image URLs)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Google Maps (optional — the app works key-free via the maps.google.com embed
# pattern; set this only if you want the JS Maps SDK / Places Autocomplete later)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Resend (optional — get a key at resend.com to enable email alerts on
# suspicious login activity; leave blank to skip)
RESEND_API_KEY=""
SECURITY_ALERT_EMAIL=""

# reCAPTCHA v3 (optional — get keys at google.com/recaptcha to enable bot
# protection on the register / list-your-venue forms; leave blank to skip)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

NEXT_PUBLIC_SITE_NAME="To'yxonaTop"
